{
  "plugins": {
    "usbfilewatcher": {
      "watchFolders": ["/media/usb1", "/media/usb2", "/media/usb3", "/media/usb4"],
      "copyFolder": "~/.octoprint/uploads/USB",
      "fileAction": "rename",
      "copyFileTypes": [".gcode", ".gco", ".g", ".stl"],
      "userFeedback": "log",
      "autoMonitor": true,
      "monitorInterval": 5,
      "debug_logging": false,
      "autoUnmount": true,
      "unmountDelay": 3,
      "enterpriseMode": true
    }
  }
}
